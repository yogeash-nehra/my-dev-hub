# ─── Anthropic ─────────────────────────────────────────────────────────────────
# Required for all AI features (trading agents, skills generator, flow builder)
# Get your key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Alpha Vantage ─────────────────────────────────────────────────────────────
# Required for the Trading Agent page — fetches real market data (quote, financials,
# technicals, news sentiment) per ticker.
# Free tier: 25 req/day, 5 req/min — sufficient for occasional manual analyses.
# Premium key recommended if you run multiple analyses per day.
# Get your key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_key_here

# ─── Trading: optional overrides ───────────────────────────────────────────────
# Override the default Claude model used by the trading agent pipeline.
# Defaults to claude-sonnet-4-6 when not set.
# TRADING_MODEL=claude-sonnet-4-6

# ─── Vercel KV (portfolio persistence) ────────────────────────────────────────
# Required for portfolio position storage. Create a KV database in Vercel:
#   Dashboard → Storage → Create Database → KV → link to this project.
# Vercel auto-populates these env vars when you link the KV store.
# For local dev: run `vercel env pull .env.local` to download them.
KV_REST_API_URL=https://your-kv-url.kv.vercel-storage.com
KV_REST_API_TOKEN=your_token_here

# ─── Vercel deployment ─────────────────────────────────────────────────────────
# In Vercel: Settings → Environment Variables — add ANTHROPIC_API_KEY and
# ALPHA_VANTAGE_API_KEY. Both are already configured in the production deployment.
# For local dev: copy this file to .env.local and fill in your values.
